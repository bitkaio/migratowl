# =============================================================================
# MigratOwl — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines starting with # are comments. Uncomment and set as needed.

# =============================================================================
# Third-party API keys (read directly by their SDKs — no MIGRATOWL_ prefix)
# =============================================================================

# Anthropic — required for the LLM agent
ANTHROPIC_API_KEY=

# OpenAI — optional, for embeddings or alternative models
# OPENAI_API_KEY=

# LangFuse — optional, for observability/tracing
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# MigratOwl settings (all prefixed with MIGRATOWL_)
# =============================================================================

# LLM model name passed to ChatAnthropic
# MIGRATOWL_MODEL_NAME=claude-sonnet-4-6

# Kubernetes sandbox — template name for agent-sandbox mode
# MIGRATOWL_SANDBOX_TEMPLATE=migratowl-sandbox-template

# Kubernetes sandbox — namespace to create sandboxes in
# MIGRATOWL_SANDBOX_NAMESPACE=default

# Kubernetes sandbox — connection mode (tunnel | direct)
# MIGRATOWL_SANDBOX_CONNECTION_MODE=tunnel

# Path inside the sandbox where repositories are cloned
# MIGRATOWL_WORKSPACE_PATH=/home/user/workspace

# Max concurrent registry queries when checking for outdated dependencies
# MIGRATOWL_SCAN_REGISTRY_CONCURRENCY=10
